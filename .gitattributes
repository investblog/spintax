# Force LF line endings on shipped files. Without this the Windows
# checkout reapplies CRLF on every git operation, which has tripped
# both PHPCS (the EOL-character sniff) and the lint:php shell scripts
# (bash chokes on `\r` in script lines).

* text=auto eol=lf

*.php   text eol=lf
*.sh    text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.xml   text eol=lf
*.css   text eol=lf
*.dist  text eol=lf
