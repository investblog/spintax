<?xml version="1.0"?>
<phpunit
	bootstrap="tests/bootstrap.php"
	backupGlobals="false"
	colors="true"
>
	<testsuites>
		<!--
			Suffix is "Test.php", not ".php": PHPUnit *includes* every file it matches, so a plain
			".php" suffix executes any helper or scratch script that happens to sit in tests/ —
			render-preview.php wrote a file on every run, and bootstrap.php needed an explicit
			<exclude> to stay out of the suite. Matching only real test files removes that whole class
			of surprise.
		-->
		<testsuite name="plugin">
			<directory suffix="Test.php">./tests</directory>
		</testsuite>
	</testsuites>
	<php>
		<const name="WP_TESTS_MULTISITE" value="0"/>
	</php>
</phpunit>
